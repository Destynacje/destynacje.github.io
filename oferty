<!DOCTYPE html>
<html lang="pl">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Oferty — Destynacje</title>

<style>

body{
margin:0;
font-family:Arial,sans-serif;
background:#eef7ea;
}

header{
background:#dff0d8;
padding:20px;
text-align:center;
}

header img{
width:280px;
max-width:90%;
}

nav{
background:#6bbf59;
display:flex;
justify-content:center;
flex-wrap:wrap;
}

nav a{
color:white;
padding:18px 25px;
text-decoration:none;
font-weight:bold;
}

nav a:hover{
background:#57a548;
}

.hero{
height:300px;

background:
linear-gradient(rgba(0,0,0,0.4),
rgba(0,0,0,0.4)),
url('https://images.unsplash.com/photo-1507525428034-b723cf961d3e?q=80&w=1600&auto=format&fit=crop');

background-size:cover;
background-position:center;

display:flex;
align-items:center;
justify-content:center;

color:white;
font-size:50px;
font-weight:bold;
}

.container{
max-width:1200px;
margin:auto;
padding:50px 20px;
}

.offers-grid{

display:grid;

grid-template-columns:
repeat(auto-fit,minmax(300px,1fr));

gap:30px;

}

.offer-card{

background:white;

border-radius:20px;

overflow:hidden;

box-shadow:0 4px 15px rgba(0,0,0,0.1);

transition:0.3s;

}

.offer-card:hover{

transform:translateY(-5px);

}

.offer-card img{

width:100%;
height:220px;
object-fit:cover;

}

.offer-content{

padding:20px;

}

.offer-content h2{

margin-top:0;
color:#4f9f3d;

}

.price{

font-size:24px;
font-weight:bold;
margin:15px 0;
color:#222;

}

button{

background:#6bbf59;
color:white;
border:none;
padding:14px 22px;
border-radius:10px;
cursor:pointer;
font-weight:bold;

}

button:hover{
background:#57a548;
}

</style>

</head>

<body>

<header>

<img src="logo.png">

</header>

<nav>

<a href="index.html">Strona główna</a>

<a href="oferty.html">Oferty</a>

<a href="profil.html">Profil</a>

</nav>

<div class="hero">

Nasze oferty

</div>

<div class="container">

<div class="offers-grid">

<!-- OFERTA 1 -->

<div class="offer-card">

<img src="https://images.unsplash.com/photo-1507525428034-b723cf961d3e?q=80&w=1200&auto=format&fit=crop">

<div class="offer-content">

<h2>Grecja — Kreta</h2>

<p>
7 dni all inclusive
</p>

<div class="price">
2999 zł
</div>

<a href="oferta-grecja.html">

<button>
Zobacz ofertę
</button>

</a>

</div>

</div>

<!-- OFERTA 2 -->

<div class="offer-card">

<img src="https://images.unsplash.com/photo-1517821365201-7734f463f9a0?q=80&w=1200&auto=format&fit=crop">

<div class="offer-content">

<h2>Norwegia — Fiordy</h2>

<p>
Wycieczka po fiordach
</p>

<div class="price">
4599 zł
</div>

<a href="oferta-norwegia.html">

<button>
Zobacz ofertę
</button>

</a>

</div>

</div>

</div>

</div>

</body>
</html>
